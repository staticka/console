{
  "name": "staticka/console",
  "description": "Terminal-based package for Staticka.",
  "keywords": [ "php-console", "site-generator" ],
  "homepage": "https://roug.in/staticka/console/",
  "license": "MIT",
  "authors":
  [
    {
      "email": "rougingutib@gmail.com",
      "homepage": "https://roug.in/",
      "name": "Rougin Gutib",
      "role": "Software Engineer"
    }
  ],
  "require":
  {
    "php": ">=5.3.0",
    "rougin/blueprint": "~0.7",
    "staticka/staticka": "~0.4"
  },
  "require-dev":
  {
    "phpunit/phpunit": "*",
    "sanmai/phpunit-legacy-adapter": "*"
  },
  "bin":
  [
    "bin/staticka"
  ],
  "autoload":
  {
    "psr-4":
    {
      "Staticka\\Console\\": "src"
    }
  },
  "autoload-dev":
  {
    "psr-4":
    {
      "Staticka\\Console\\": "tests"
    }
  },
  "scripts":
  {
    "analyze": "phpstan analyse",
    "restyle": "php-cs-fixer fix --config=phpstyle.php",
    "test": "phpunit"
  }
}
